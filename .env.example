# Vite + Vercel environment variables
# In Vercel: Project Settings -> Environment Variables

# GitHub username to read public profile/repos from
VITE_GITHUB_USER=DeveloperAlejandroS

# Optional personal access token to avoid GitHub API rate limits
# Recommended scope: public_repo (classic token)
VITE_GITHUB_TOKEN=

# Optional GitHub API base URL (default: https://api.github.com)
VITE_GITHUB_API_BASE=https://api.github.com
